# ──────────────────────────────────────────────
# Synra Market — Environment Variables Template
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── MongoDB ─────────────────────────────────────
# Local: mongodb://localhost:27017/synra_market
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/synra_market
MONGODB_URI=mongodb://localhost:27017/synra_market

# ── JWT ─────────────────────────────────────────
# Generate a strong random secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Stripe ──────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — get this by running:
#   stripe listen --forward-to localhost:3000/api/webhook
# Or from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Nodemailer + Gmail) ──────────────────
# Your Gmail address
EMAIL_FROM=your-email@gmail.com
# Generate an App Password at:
#   Google Account → Security → 2-Step Verification → App Passwords
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── App URL ─────────────────────────────────────
# Local development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production (Vercel)
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app
